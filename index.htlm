<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Victoria Exams SPA</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
<style>
/* Design Global */
body{font-family:'Poppins', sans-serif;margin:0;background:#f0f4f8;color:#2d3436;overflow-x: hidden;}
header{background:linear-gradient(135deg,#6c5ce7,#a29bfe);color:white;padding:40px 20px;text-align:center;font-size:30px;font-weight:600;border-bottom-left-radius:50px;border-bottom-right-radius:50px;box-shadow:0 10px 30px rgba(108,92,231,0.2)}
.container{max-width:1100px;margin:auto;padding:20px}
h2{text-align:center;margin-top:40px;font-weight:600;color:#4834d4}

/* Cartes Très Arrondies */
.card, .class-card, .top-card {
    background:white;
    padding:20px;
    border-radius:24px;
    text-align:center;
    box-shadow:0 10px 20px rgba(0,0,0,0.05);
    transition:all 0.3s ease;
    cursor:pointer;
    border: 1px solid rgba(0,0,0,0.02);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.card:hover, .class-card:hover, .top-card:hover {
    transform:translateY(-5px);
    box-shadow:0 15px 30px rgba(108,92,231,0.15);
    background: #f8f9ff;
}

/* Grilles */
.top-row, .classes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 20px;
    margin-top: 25px;
}

.classes {
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
}

.preview{height:80px;background:#f1f2f6;border-radius:18px;margin-top:10px}

/* Navigation & Grille Matières */
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:20px;margin-top:30px}
.section{display:none;animation: fadeIn 0.5s ease;}
.active{display:block}
@keyframes fadeIn { from {opacity:0; transform:translateY(10px);} to {opacity:1; transform:translateY(0);} }

.back{display:inline-block;margin-top:40px;padding:12px 25px;background:#6c5ce7;color:white;border-radius:50px;text-decoration:none;font-weight:600;transition:0.3s;cursor:pointer}
.back:hover{background:#4834d4;transform:scale(1.05)}
.center-btn { text-align: center; }

/* Couleurs spécifiques */
.type-cc { border-left: 8px solid #00cec9; }
.type-eval { border-left: 8px solid #ff7675; }

@media (max-width: 480px) {
    .top-row { grid-template-columns: repeat(2, 1fr); gap: 10px; }
    .classes { grid-template-columns: 1fr; }
}
</style>
</head>

<body>

<header>Victoria Exams Portal</header>

<div class="container">

<div class="section active" id="home">
    <h2>🔥 Top des épreuves</h2>
    <div class="top-row">
        <div class="top-card" onclick="openTop('Maths', 'Troisième')">Maths 3e<div class="preview"></div></div>
        <div class="top-card" onclick="openTop('Philosophie', 'Terminale')">Philosophie Tle<div class="preview"></div></div>
        <div class="top-card" onclick="openTop('SVT', 'Première')">SVT 1ère<div class="preview"></div></div>
        <div class="top-card" onclick="openTop('Anglais', 'Troisième')">Anglais 3e<div class="preview"></div></div>
    </div>

    <h2>🎓 Classes d’examen</h2>
    <div class="classes">
        <div class="class-card" onclick="showClass('Troisième')">✨ Classe de Troisième</div>
        <div class="class-card" onclick="showClass('Première')">🚀 Classe de Première</div>
        <div class="class-card" onclick="showClass('Terminale')">🎓 Classe de Terminale</div>
    </div>
</div>

<div class="section" id="subjects-page">
    <h2 id="subjects-title">Matières</h2>
    <div class="grid" id="subjects-grid"></div>
    <div class="center-btn"><a class="back" onclick="showSection('home')">⬅ Retour aux classes</a></div>
</div>

<div class="section" id="years-page">
    <h2 id="year-title">Choisir l'année</h2>
    <div class="grid">
        <div class="card" onclick="selectYear('2023')">📅 Année 2023</div>
        <div class="card" onclick="selectYear('2024')">📅 Année 2024</div>
        <div class="card" onclick="selectYear('2025')">📅 Année 2025</div>
    </div>
    <div class="center-btn"><a class="back" onclick="showSection('subjects-page')">⬅ Retour aux matières</a></div>
</div>

<div class="section" id="type-page">
    <h2 id="type-title">Quel type d'épreuve ?</h2>
    <div class="grid" style="max-width:700px; margin:auto">
        <div class="card type-cc" onclick="finishSelection('CC')">
            <h3 style="margin:0">📝 Contrôle Continu</h3>
            <p style="color: #636e72">Devoirs de classe</p>
        </div>
        <div class="card type-eval" onclick="finishSelection('Évaluation')">
            <h3 style="margin:0">🎓 Évaluation</h3>
            <p style="color: #636e72">Séquences et Examens</p>
        </div>
    </div>
    <div class="center-btn"><a class="back" onclick="showSection('years-page')">⬅ Retour aux années</a></div>
</div>

</div>

<script>
let state = { class: "", subject: "", year: "" };

// --- CONFIGURATION DE TES LIENS DRIVE ---
// Remplace les liens ci-dessous par tes liens Google Drive réels
const DRIVE_LINKS = {
    "Troisième": {
        "Mathématiques": {
            "2024": { "CC": "LIEN_DRIVE_ICI", "Évaluation": "LIEN_DRIVE_ICI" }
        },
        "PCT": {
            "2024": { "CC": "LIEN_DRIVE_ICI", "Évaluation": "LIEN_DRIVE_ICI" }
        }
    },
    "Terminale": {
        "Philosophie": {
            "2024": { "Évaluation": "https://drive.google.com/your-file-link" }
        }
    }
};

function showSection(id){
    document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    window.scrollTo(0,0);
}

function showClass(className) {
    state.class = className;
    document.getElementById('subjects-title').innerText = "Classe de " + className;
    const grid = document.getElementById('subjects-grid');
    grid.innerHTML = ''; 
    
    let subjects = ["Mathématiques", "Français", "SVT", "Histoire-Géo", "Informatique", "Anglais","Espagnol", "Allemand" ,"Arabe"];
    
    if(className === "Troisième") {
        subjects.push("PCT");
    } else {
        subjects.push("Physique", "Chimie", "Philosophie");
    }

    subjects.forEach(sub => {
        const card = document.createElement('div');
        card.className = 'card';
        card.innerText = sub;
        card.onclick = () => selectSubject(sub);
        grid.appendChild(card);
    });
    showSection('subjects-page');
}

function selectSubject(subjectName) {
    state.subject = subjectName;
    document.getElementById('year-title').innerText = subjectName + " (" + state.class + ")";
    showSection('years-page');
}

function selectYear(year) {
    state.year = year;
    document.getElementById('type-title').innerText = state.subject + " - Session " + year;
    showSection('type-page');
}

function finishSelection(type) {
    // Tentative de récupération du lien dans la base de données ci-dessus
    try {
        const link = DRIVE_LINKS[state.class][state.subject][state.year][type];
        if (link && link !== "LIEN_DRIVE_ICI") {
            window.open(link, '_blank');
        } else {
            alert("Lien non disponible pour cette sélection.\nChemin : " + state.class + " > " + state.subject + " > " + state.year);
        }
    } catch (e) {
        alert("Lien non encore configuré pour cette épreuve.");
    }
}

// Fonction pour les raccourcis "Top"
function openTop(subject, classe) {
    alert("Ouverture rapide de l'épreuve " + subject + " (" + classe + ")");
    // Ici tu peux aussi rediriger vers un lien direct
}
</script>

</body>
</html>
